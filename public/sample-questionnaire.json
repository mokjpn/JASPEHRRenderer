{
  "resourceType": "Questionnaire",
  "id": "jaspehr-demo-001",
  "url": "http://example.org/fhir/Questionnaire/jaspehr-demo-001",
  "status": "active",
  "title": "JASPEHR SDC Demo",
  "item": [
    {
      "linkId": "g1",
      "text": "患者情報",
      "type": "group",
      "item": [
        {
          "linkId": "gender",
          "text": "性別",
          "type": "choice",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-itemControl",
              "valueCodeableConcept": {
                "coding": [
                  {
                    "system": "http://hl7.org/fhir/questionnaire-item-control",
                    "code": "radio-button"
                  }
                ]
              }
            }
          ],
          "answerOption": [
            {
              "valueCoding": {
                "system": "http://example.org/gender",
                "code": "male",
                "display": "男性"
              }
            },
            {
              "valueCoding": {
                "system": "http://example.org/gender",
                "code": "female",
                "display": "女性"
              },
              "initialSelected": true
            }
          ]
        },
        {
          "linkId": "pregnancy_week",
          "text": "妊娠週数",
          "type": "integer",
          "enableWhen": [
            {
              "question": "gender",
              "operator": "=",
              "answerCoding": {
                "system": "http://example.org/gender",
                "code": "female"
              }
            }
          ],
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%age / 2"
              }
            }
          ]
        },
        {
          "linkId": "age",
          "text": "年齢",
          "type": "integer",
          "required": true,
          "minValue": {
            "value": 0
          },
          "maxValue": {
            "value": 130
          },
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-initialExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "30"
              }
            }
          ]
        },
        {
          "linkId": "roman_name",
          "text": "氏名（ローマ字表記）",
          "type": "string",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/regex",
              "valueString": "^[A-Za-z0-9 ]+$"
            }
          ]
        },
        {
          "linkId": "height_cm",
          "text": "身長(cm)",
          "type": "decimal",
          "required": true,
          "minValue": {
            "value": 50
          },
          "maxValue": {
            "value": 250
          }
        },
        {
          "linkId": "weight_kg",
          "text": "体重(kg)",
          "type": "decimal",
          "required": true,
          "minValue": {
            "value": 1
          },
          "maxValue": {
            "value": 300
          }
        },
        {
          "linkId": "score",
          "text": "BMI(自動計算)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%height_cm > 0 && %weight_kg > 0 ? %weight_kg / ((%height_cm / 100) * (%height_cm / 100)) : null"
              }
            }
          ]
        },
        {
          "linkId": "visit_date",
          "text": "受診日",
          "type": "date",
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-initialExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "today()"
              }
            }
          ]
        }
      ]
    }
  ]
}
